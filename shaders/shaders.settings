/* /shaders/shaders.settings */
/* DOSGL-13h — GL 4.1 */

#define DOS_SATURATION 1.0
#define DOS_CONTRAST   1.0

/* Downscale factor: 1280x800 / 4 = 320x200 (Mode 13h) */
#define DOS_SCALE 4 // [1 2 3 4 5 6 7 8]

/* Ambient floor — minimum lightmap brightness to avoid pure black */
#define AMBIENT_FLOOR 0.05 // [0.00 0.05 0.10 0.15 0.20 0.25 0.30 0.35 0.40 0.45 0.50 0.55 0.60]

/* Light quantization steps (0 = off, 16 matches vanilla light levels) */
#define DOS_LIGHT_STEPS 16 // [0 2 4 8 16 32 64]

/* Palette mode: 0 = 6x6x6 cube (216 colors), 1 = RGB332 (256 colors) */
#define DOS_PALETTE_256 1 // [0 1]

/* Bypass: disables color grading and palette quantization entirely */
#define DOS_PALETTE_BYPASS 0 // [0 1]

/* ===== Affine Texture Mapping ===== */
#define DOS_AFFINE_ENABLE 1    // [0 1]
#define DOS_AFFINE_NEAR   0.00 // [0.00 0.25 0.50 0.75 1.00 1.50 2.00 3.00]
#define DOS_AFFINE_RANGE  1.50 // [0.00 0.50 1.00 1.25 1.50 2.00 3.00]

/* ===== Fog Tuning =====
   Multipliers and offsets applied to vanilla fog parameters.
   Does not change fog mode or shape — only adjusts distances/density. */
#define FOG_TUNE_ENABLE   1    // [0 1]
#define FOG_START_SCALE   0.75 // [0.25 0.50 0.75 1.00 1.25 1.50 2.00 3.00]
#define FOG_START_ADD     0    // [-128 -64 -32 -16 -8 -4 0 4 8 16 32 64 128]
#define FOG_END_SCALE     1.00 // [0.25 0.50 0.75 1.00 1.25 1.50 2.00 3.00]
#define FOG_END_ADD       0    // [-256 -128 -64 -32 -16 -8 0 8 16 32 64 128 256]
#define FOG_DENSITY_SCALE 1.00 // [0.25 0.50 0.75 1.00 1.25 1.50 2.00 3.00 4.00]
#define FOG_MIN_RANGE     1.00 // [0.10 0.50 1.00 2.00 4.00 8.00 16.00]

/* ===== Hands ===== */
#define HAND_FLATTEN        1    // [0 1]
#define HAND_DITHER         1    // [0 1]
#define HAND_DITHER_STRENGTH 1.00 // [0.00 0.25 0.50 0.75 1.00]

/* ===== Add-on Toggles ===== */
#define FLATTER_SIGNS  0 // [0 1]
#define BILLY_BOARDING 0 // [0 1]